    print(f"  R optimal = {Ro:.4f} N   ({100*(Ri-Ro)/Ri:.1f}% reduction)")
    print(f"  V optimal = {Vo:.5f} m3  (band: +/-{gamma*100:.0f}% of {V_ref:.5f})")

    plot_hull(h0, h_opt, cp_surr, R_surr, V_surr)